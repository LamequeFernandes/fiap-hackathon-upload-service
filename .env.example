# upload-service — variáveis de ambiente

# Banco de dados PostgreSQL (upload_db)
DATABASE_URL=postgresql+asyncpg://upload_user:upload_pass@localhost:5432/upload_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/
RABBITMQ_EXCHANGE=arch_analyzer
RABBITMQ_QUEUE=analysis.process
RABBITMQ_ROUTING_KEY=analysis.process

# MinIO (object storage)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=diagrams
MINIO_SECURE=false

# Limite de tamanho de arquivo
MAX_FILE_SIZE_MB=10

# Observabilidade
SERVICE_NAME=upload-service
LOG_LEVEL=INFO
